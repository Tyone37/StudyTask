{
  "name": "student-task-manager",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "npm run dev",
    "dev": "concurrently -k -n API,WEB -c cyan,green \"npm run start:server\" \"npm run start:client\"",
    "start:client": "ng serve --host 0.0.0.0 --port 4200",
    "start:server": "node server/server.js",
    "setup:db": "node server/scripts/setup-db.js",
    "check:db": "node server/scripts/check-db.js",
    "build": "ng build"
  },
  "dependencies": {
    "@angular/animations": "21.2.15",
    "@angular/common": "21.2.15",
    "@angular/compiler": "21.2.15",
    "@angular/core": "21.2.15",
    "@angular/forms": "21.2.15",
    "@angular/platform-browser": "21.2.15",
    "@angular/router": "21.2.15",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.15.3",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "21.2.13",
    "@angular/cli": "21.2.13",
    "@angular/compiler-cli": "21.2.15",
    "concurrently": "^9.2.1",
    "typescript": "5.9.3"
  },
  "description": "Ứng dụng Angular + Express + MySQL để sinh viên quản lý todo, ghi chú và deadline học tập.",
